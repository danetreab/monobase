{
  "name": "@repo/auth",
  "version": "0.0.1",
  "description": "Auth microservice (NestJS + better-auth + Drizzle/Postgres)",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "lint": "eslint src --max-warnings 0",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "auth:generate": "bunx @better-auth/cli generate --config src/auth/auth.ts --output ../../../packages/db/src/schema.ts -y"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/microservices": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@repo/db": "*",
    "@thallesp/nestjs-better-auth": "^2.6.0",
    "better-auth": "^1.6.9",
    "dotenv": "^16.4.7",
    "ioredis": "^5.4.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.2"
  }
}
