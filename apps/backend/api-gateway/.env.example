DATABASE_URL=postgres://user:password@host:5432/database
REDIS_URL=redis://localhost:6379
AUTH_SERVICE_URL=http://localhost:3001
BETTER_AUTH_SECRET=replace_with_openssl_rand_base64_32
BETTER_AUTH_URL=http://localhost:3000
PORT=3000
GRAPHQL_TCP_HOST=127.0.0.1
GRAPHQL_TCP_PORT=4002
# Comma-separated allowed origins for browser CORS. Required in prod
# (we can't use "*" with credentials). Defaults to the dev frontends.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
# Set to ".yourdomain.com" in production to share the session cookie across subdomains.
# AUTH_COOKIE_DOMAIN=
