    },
    {
      "key": "user_password",
      "value": "password123",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string",
      "description": "Populated by Sign Up / Sign In via test scripts."
    },
    {
      "key": "created_user_id",
      "value": "",
      "type": "string",
      "description": "Populated by GraphQL Create One User test script. Used by Get / Update One / Delete One."
    },
    {
      "key": "upload_url",
      "value": "",
      "type": "string",
      "description": "Populated by GraphQL → Files → Create Upload URL. Used by 'Upload Binary to MinIO'."
    },
    {
      "key": "file_key",
      "value": "",
      "type": "string",
      "description": "Populated by GraphQL → Files → Create Upload URL. Used by 'Register Upload' and 'Get File by ID'."
    },
    {
      "key": "file_content_type",
      "value": "application/octet-stream",
      "type": "string",
      "description": "Sent as Content-Type to both Create Upload URL and the direct PUT to MinIO. They MUST match — MinIO rejects the PUT otherwise because the presigned URL is bound to the Content-Type used at presign time."
    },
    {
      "key": "created_file_id",
      "value": "",
      "type": "string",
      "description": "Populated by Register Upload — the file row id."
    }
  ],
