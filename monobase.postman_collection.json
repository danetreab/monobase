              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation CreateOneItem($input: CreateOneItemInput!) {\n  createOneItem(input: $input) {\n    id\n    name\n    description\n    price\n    createdAt\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"item\": {\n      \"name\": \"Sample Widget\",\n      \"description\": \"Created via Postman\",\n      \"price\": 19.99\n    }\n  }\n}"
              }
