    {
      "name": "GraphQL — Admin Items (CRUD)",
      "description": "CrudResolver over the item table from @repo/db. Supports the same nestjs-query filter/paging/sorting + Input-wrapper mutation convention as Admin Users.\n\nThe Item type exposes a `files: [ItemFile!]!` resolve-field that loads any uploaded files attached via the polymorphic uploaded_file table (entityType='item', entityId=<itemId>). Files are uploaded over REST — see the 'Item Files (multipart upload)' folder.",
      "item": [
        {
          "name": "List Items",
          "description": "Paginated list with filter, sort, and the polymorphic files resolve-field.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query Items(\n  $filter: ItemFilter\n  $paging: OffsetPaging\n  $sorting: [ItemSort!]\n) {\n  items(filter: $filter, paging: $paging, sorting: $sorting) {\n    nodes {\n      id\n      name\n      description\n      price\n      createdAt\n      updatedAt\n      files {\n        id\n        filename\n        originalFilename\n        mimetype\n        size\n        url\n        thumbnailUrl\n        hasThumbnail\n        createdAt\n      }\n    }\n    totalCount\n    pageInfo {\n      hasNextPage\n      hasPreviousPage\n    }\n  }\n}",
                "variables": "{\n  \"filter\": {},\n  \"paging\": { \"limit\": 25, \"offset\": 0 },\n  \"sorting\": [{ \"field\": \"createdAt\", \"direction\": \"DESC\" }]\n}"
              }
            },
            "url": {
              "raw": "{{gateway_url}}/graphql/v1",
              "host": ["{{gateway_url}}"],
              "path": ["graphql", "v1"]
            }
          }
        },
        {
          "name": "Get Item by ID",
          "description": "Uses {{created_item_id}} captured by Create One Item.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query Item($id: ID!) {\n  item(id: $id) {\n    id\n    name\n    description\n    price\n    createdAt\n    updatedAt\n    files {\n      id\n      filename\n      originalFilename\n      mimetype\n      size\n      url\n      thumbnailUrl\n      hasThumbnail\n      createdAt\n    }\n  }\n}",
                "variables": "{\n  \"id\": \"{{created_item_id}}\"\n}"
              }
            },
            "url": {
              "raw": "{{gateway_url}}/graphql/v1",
              "host": ["{{gateway_url}}"],
              "path": ["graphql", "v1"]
            }
          }
        },
        {
          "name": "Create One Item",
          "description": "Test script captures the new id into {{created_item_id}}, used by the Update / Delete / file-upload requests.",
