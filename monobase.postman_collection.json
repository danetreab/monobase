    },
    {
      "name": "GraphQL — Files (Upload)",
      "description": "Two-phase generic file upload against MinIO.\n\n1. Create Upload URL — server presigns a PUT against MinIO and inserts a pending file row owned by the caller. Returns { uploadUrl, fileKey, bucket, expiresInSeconds }. Test script saves uploadUrl + fileKey into collection vars.\n2. Upload Binary to MinIO — direct PUT to the presigned URL with the binary body. Run this OUTSIDE the gateway (no Origin/auth). Content-Type MUST match the value passed to createUploadUrl.\n3. Register Upload — server stat-checks the object in MinIO and flips the row to completed (size + etag). Test script saves the file row id into {{created_file_id}}.\n\nAll three GraphQL operations run through the gateway and require an authenticated session (any role). Listing/find scopes to the caller; admins see every file.",
      "item": [
        {
          "name": "Create Upload URL",
          "description": "Step 1. Sets {{upload_url}} and {{file_key}} for the next step.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const data = json && json.data && json.data.createUploadUrl;",
                  "if (data) {",
                  "  pm.collectionVariables.set('upload_url', data.uploadUrl);",
                  "  pm.collectionVariables.set('file_key', data.fileKey);",
                  "  console.log('Saved upload_url + file_key:', data.fileKey);",
                  "} else if (json && json.errors) {",
                  "  console.log('GraphQL errors:', JSON.stringify(json.errors));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation CreateUploadUrl($input: CreateUploadUrlInput!) {\n  createUploadUrl(input: $input) {\n    uploadUrl\n    fileKey\n    bucket\n    expiresInSeconds\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"originalName\": \"report.pdf\",\n    \"contentType\": \"{{file_content_type}}\",\n    \"sizeBytes\": 2048\n  }\n}"
              }
            },
            "url": {
              "raw": "{{gateway_url}}/graphql/v1",
              "host": ["{{gateway_url}}"],
              "path": ["graphql", "v1"]
            }
          }
        },
        {
          "name": "Upload Binary to MinIO",
          "description": "Step 2 — direct PUT to the presigned URL captured in {{upload_url}}. Pick a file in the request body (Body → binary) before sending. The Content-Type MUST equal {{file_content_type}} (the same value you passed to createUploadUrl) — MinIO rejects the PUT otherwise.\n\nThis request bypasses the collection's Origin pre-request via a request-level override (better-auth doesn't sit on this path, but the extra header confuses some MinIO setups). It does NOT need to go through the gateway.",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Strip the collection-level Origin header — MinIO's presign signature",
                  "// covers the host + query, and an unexpected Origin can also break CORS",
                  "// preflight on some setups.",
                  "pm.request.headers.remove('Origin');"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "{{file_content_type}}"
              }
            ],
            "body": {
              "mode": "file",
              "file": {}
            },
            "url": {
              "raw": "{{upload_url}}",
              "host": ["{{upload_url}}"]
            }
          }
        },
        {
          "name": "Register Upload",
          "description": "Step 3. Confirms the upload — server stats the object in MinIO and flips the row to completed.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const data = json && json.data && json.data.registerUpload;",
                  "if (data && data.id) {",
                  "  pm.collectionVariables.set('created_file_id', data.id);",
                  "  console.log('Saved created_file_id:', data.id);",
                  "} else if (json && json.errors) {",
                  "  console.log('GraphQL errors:', JSON.stringify(json.errors));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation RegisterUpload($input: RegisterUploadInput!) {\n  registerUpload(input: $input) {\n    id\n    key\n    bucket\n    originalName\n    contentType\n    sizeBytes\n    etag\n    status\n    uploadedBy\n    createdAt\n    completedAt\n    updatedAt\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"fileKey\": \"{{file_key}}\"\n  }\n}"
              }
            },
            "url": {
              "raw": "{{gateway_url}}/graphql/v1",
              "host": ["{{gateway_url}}"],
              "path": ["graphql", "v1"]
            }
          }
        },
        {
          "name": "List Files (mine)",
          "description": "Returns every file owned by the caller. Admins see all files in the bucket.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query Files {\n  files {\n    id\n    key\n    bucket\n    originalName\n    contentType\n    sizeBytes\n    etag\n    status\n    uploadedBy\n    createdAt\n    completedAt\n    updatedAt\n  }\n}",
                "variables": ""
              }
            },
            "url": {
              "raw": "{{gateway_url}}/graphql/v1",
              "host": ["{{gateway_url}}"],
              "path": ["graphql", "v1"]
            }
          }
        },
        {
          "name": "Get File by ID",
          "description": "Uses {{created_file_id}} captured by Register Upload.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query File($id: ID!) {\n  file(id: $id) {\n    id\n    key\n    bucket\n    originalName\n    contentType\n    sizeBytes\n    etag\n    status\n    uploadedBy\n    createdAt\n    completedAt\n    updatedAt\n  }\n}",
                "variables": "{\n  \"id\": \"{{created_file_id}}\"\n}"
              }
            },
            "url": {
              "raw": "{{gateway_url}}/graphql/v1",
              "host": ["{{gateway_url}}"],
              "path": ["graphql", "v1"]
            }
          }
        }
      ]
    }
  ]
}
