              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const id = json && json.data && json.data.createOneItem && json.data.createOneItem.id;",
                  "if (id) {",
                  "  pm.collectionVariables.set('created_item_id', id);",
                  "  console.log('Saved created_item_id:', id);",
                  "} else if (json && json.errors) {",
                  "  console.log('GraphQL errors:', JSON.stringify(json.errors));",
                  "}"
                ]
              }
            }
          ],
          "request": {
