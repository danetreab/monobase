                "query": "mutation DeleteOneUser($input: DeleteOneUserInput!) {\n  deleteOneUser(input: $input) {\n    id\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"id\": \"{{created_user_id}}\"\n  }\n}"
              }
            },
            "url": {
              "raw": "{{gateway_url}}/graphql/v1",
              "host": ["{{gateway_url}}"],
              "path": ["graphql", "v1"]
            }
          }
        },
        {
          "name": "Delete Many Users",
