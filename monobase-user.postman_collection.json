{
  "info": {
    "name": "Monobase — User Service",
    "description": "User-focused subset of the Monobase API: better-auth flows (sign-up / sign-in / session / sign-out), the better-auth admin plugin endpoints (role / ban / remove), and the GraphQL user CRUD generated by the CrudResolver in @repo/graphql against the shared user table from @repo/db.\n\nAll requests go through the gateway at {{gateway_url}}. The gateway proxies /api/auth/* to the auth service and forwards POST /graphql into the graphql service over the Redis microservice transport.\n\nSession handling: Postman keeps cookies automatically — better-auth sets the session cookie on sign-in and the same cookie is sent on get-session, /api/auth/admin/*, and authed /graphql calls.\n\nOrigin header: better-auth enforces an Origin check on authenticated state-changing requests. The collection-level pre-request script sets Origin: {{gateway_url}} on every request.\n\nSubscriptions (createdUser / updatedOneUser / deletedOneUser) are not included — Postman models WebSocket transport separately. Open a Postman WebSocket request to ws://localhost:3000/graphql to test them.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// better-auth requires Origin header on authenticated state-changing requests",
          "// (CSRF protection). Always send the gateway URL as Origin.",
          "const gatewayUrl = pm.collectionVariables.get('gateway_url');",
          "if (gatewayUrl) {",
          "  pm.request.headers.upsert({ key: 'Origin', value: gatewayUrl });",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "gateway_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "admin_email",
      "value": "admin@example.com",
      "type": "string"
    },
    {
      "key": "admin_password",
      "value": "password123",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string",
      "description": "Populated by Sign Up / Sign In via test scripts. Used by admin/* operations."
    },
    {
      "key": "created_user_id",
      "value": "",
      "type": "string",
      "description": "Populated by GraphQL Create One User test script. Used by Get / Update One / Delete One."
    }
  ],
  "item": [
    {
      "name": "Auth (via gateway)",
      "description": "better-auth flows proxied through the gateway. The dashboard talks to auth this way — never hit :3001 directly in real flows because the better-auth session cookie is scoped to the gateway origin.",
      "item": [
        {
          "name": "Sign Up (email)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.user && json.user.id) {",
                  "  pm.collectionVariables.set('user_id', json.user.id);",
                  "  console.log('Saved user_id:', json.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\",\n  \"name\": \"Admin\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/auth/sign-up/email",
              "host": ["{{gateway_url}}"],
              "path": ["api", "auth", "sign-up", "email"]
            }
          },
          "response": []
        },
        {
          "name": "Sign In (email)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.user && json.user.id) {",
                  "  pm.collectionVariables.set('user_id', json.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/auth/sign-in/email",
              "host": ["{{gateway_url}}"],
              "path": ["api", "auth", "sign-in", "email"]
            }
          }
        },
        {
          "name": "Get Session",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/api/auth/get-session",
              "host": ["{{gateway_url}}"],
              "path": ["api", "auth", "get-session"]
            }
          }
        },
        {
          "name": "Sign Out",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/auth/sign-out",
              "host": ["{{gateway_url}}"],
              "path": ["api", "auth", "sign-out"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin (better-auth admin plugin)",
      "description": "Endpoints provided by better-auth's admin() plugin. Requires the calling user to have role='admin' in the user table. Promote a user with: UPDATE \"user\" SET role='admin' WHERE email='...';",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/api/auth/admin/list-users?limit=100",
              "host": ["{{gateway_url}}"],
              "path": ["api", "auth", "admin", "list-users"],
              "query": [
                {
                  "key": "limit",
                  "value": "100"
                }
              ]
            }
          }
        },
        {
          "name": "Set Role",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{user_id}}\",\n  \"role\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/auth/admin/set-role",
              "host": ["{{gateway_url}}"],
              "path": ["api", "auth", "admin", "set-role"]
            }
          }
        },
        {
          "name": "Ban User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{user_id}}\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/auth/admin/ban-user",
              "host": ["{{gateway_url}}"],
              "path": ["api", "auth", "admin", "ban-user"]
            }
          }
        },
        {
          "name": "Unban User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{user_id}}\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/auth/admin/unban-user",
              "host": ["{{gateway_url}}"],
              "path": ["api", "auth", "admin", "unban-user"]
            }
          }
        },
        {
          "name": "Remove User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{user_id}}\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/auth/admin/remove-user",
              "host": ["{{gateway_url}}"],
              "path": ["api", "auth", "admin", "remove-user"]
            }
          }
        }
      ]
    },
    {
      "name": "GraphQL — Admin Users (CRUD)",
      "description": "Generated by the CrudResolver in apps/backend/graphql against the user table from @repo/db. Every operation is protected by the better-auth admin AC — the calling session must have role='admin' (read=user:list, create=user:create, update=user:update, delete=user:delete).\n\nList query supports filter / paging (limit, offset) / sorting following the nestjs-query convention. Mutations follow the Input wrapper pattern: createOneUser takes { input: { user: { ... } } }, updateOneUser takes { input: { id, update: { ... } } }, deleteOneUser takes { input: { id } }, and the *Many variants take a list / filter respectively.\n\nNote: Create One User writes directly to the user table — it does not create the matching account row, so the new user cannot sign in via email/password until provisioned through better-auth.",
      "item": [
        {
          "name": "List Users",
          "description": "Paginated list with filter and sort. Returns nodes + totalCount + pageInfo.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query Users(\n  $filter: UserFilter\n  $paging: OffsetPaging\n  $sorting: [UserSort!]\n) {\n  users(filter: $filter, paging: $paging, sorting: $sorting) {\n    nodes {\n      id\n      email\n      name\n      emailVerified\n      role\n      banned\n      banReason\n      banExpires\n      createdAt\n      updatedAt\n    }\n    totalCount\n    pageInfo {\n      hasNextPage\n      hasPreviousPage\n    }\n  }\n}",
                "variables": "{\n  \"filter\": {},\n  \"paging\": { \"limit\": 25, \"offset\": 0 },\n  \"sorting\": [{ \"field\": \"createdAt\", \"direction\": \"DESC\" }]\n}"
              }
            },
            "url": {
              "raw": "{{gateway_url}}/graphql",
              "host": ["{{gateway_url}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "List Users — filtered by email",
          "description": "Example of the filter shape: nestjs-query operator object per field.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query UsersByEmail($filter: UserFilter, $paging: OffsetPaging) {\n  users(filter: $filter, paging: $paging) {\n    nodes {\n      id\n      email\n      name\n      role\n    }\n    totalCount\n  }\n}",
                "variables": "{\n  \"filter\": { \"email\": { \"iLike\": \"%@example.com\" } },\n  \"paging\": { \"limit\": 25, \"offset\": 0 }\n}"
              }
            },
            "url": {
              "raw": "{{gateway_url}}/graphql",
              "host": ["{{gateway_url}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query User($id: ID!) {\n  user(id: $id) {\n    id\n    email\n    name\n    emailVerified\n    image\n    role\n    banned\n    banReason\n    banExpires\n    createdAt\n    updatedAt\n  }\n}",
                "variables": "{\n  \"id\": \"{{created_user_id}}\"\n}"
              }
            },
            "url": {
              "raw": "{{gateway_url}}/graphql",
              "host": ["{{gateway_url}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "Create One User",
          "description": "Test script captures the new id into {{created_user_id}}.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const id = json && json.data && json.data.createOneUser && json.data.createOneUser.id;",
                  "if (id) {",
                  "  pm.collectionVariables.set('created_user_id', id);",
                  "  console.log('Saved created_user_id:', id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation CreateOneUser($input: CreateOneUserInput!) {\n  createOneUser(input: $input) {\n    id\n    email\n    name\n    role\n    createdAt\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"user\": {\n      \"email\": \"new.user@example.com\",\n      \"name\": \"New User\",\n      \"role\": \"user\"\n    }\n  }\n}"
              }
            },
            "url": {
              "raw": "{{gateway_url}}/graphql",
              "host": ["{{gateway_url}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "Create Many Users",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation CreateManyUsers($input: CreateManyUsersInput!) {\n  createManyUsers(input: $input) {\n    id\n    email\n    name\n    role\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"users\": [\n      { \"email\": \"bulk1@example.com\", \"name\": \"Bulk One\" },\n      { \"email\": \"bulk2@example.com\", \"name\": \"Bulk Two\" }\n    ]\n  }\n}"
              }
            },
            "url": {
              "raw": "{{gateway_url}}/graphql",
              "host": ["{{gateway_url}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "Update One User",
          "description": "Uses {{created_user_id}} from Create One User by default.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation UpdateOneUser($input: UpdateOneUserInput!) {\n  updateOneUser(input: $input) {\n    id\n    email\n    name\n    role\n    banned\n    updatedAt\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"id\": \"{{created_user_id}}\",\n    \"update\": {\n      \"name\": \"Renamed User\",\n      \"role\": \"admin\"\n    }\n  }\n}"
              }
            },
            "url": {
              "raw": "{{gateway_url}}/graphql",
              "host": ["{{gateway_url}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "Update Many Users",
          "description": "Bulk update by filter. Returns { updatedCount }. Example: ban every user whose email ends with @example.com.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation UpdateManyUsers($input: UpdateManyUsersInput!) {\n  updateManyUsers(input: $input) {\n    updatedCount\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"filter\": { \"email\": { \"iLike\": \"%@example.com\" } },\n    \"update\": { \"banned\": true, \"banReason\": \"bulk-test\" }\n  }\n}"
              }
            },
            "url": {
              "raw": "{{gateway_url}}/graphql",
              "host": ["{{gateway_url}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "Delete One User",
          "description": "Returns { id } (the DeleteResponse type). Uses {{created_user_id}} by default.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation DeleteOneUser($input: DeleteOneUserInput!) {\n  deleteOneUser(input: $input) {\n    id\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"id\": \"{{created_user_id}}\"\n  }\n}"
              }
            },
            "url": {
              "raw": "{{gateway_url}}/graphql",
              "host": ["{{gateway_url}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "Delete Many Users",
          "description": "Bulk delete by filter. Returns { deletedCount }. Example deletes every user whose email starts with bulk.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation DeleteManyUsers($input: DeleteManyUsersInput!) {\n  deleteManyUsers(input: $input) {\n    deletedCount\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"filter\": { \"email\": { \"iLike\": \"bulk%@example.com\" } }\n  }\n}"
              }
            },
            "url": {
              "raw": "{{gateway_url}}/graphql",
              "host": ["{{gateway_url}}"],
              "path": ["graphql"]
            }
          }
        }
      ]
    }
  ]
}
